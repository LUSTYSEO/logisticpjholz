---
// LocationSection.astro
---

<section class="location-section">
  <div class="map-bg" style="background-image: url('/images/world_map_locations.png');"></div>
  <div class="map-overlay"></div>

  <div class="container location-container">
    <!-- Left Column: Decorative Vertical Text -->
    <div class="vertical-title-col">
      <span class="vertical-text">LOCALIZAÇÃO &bull; CONTATO &bull; GLOBAL</span>
    </div>

    <!-- Right Column: Content -->
    <div class="location-content">
      <span class="badge-tag">Conexão Global</span>
      <h2 class="section-title text-light">Descubra as Localizações dos Nossos Escritórios</h2>
      <p class="section-desc text-muted-light">
        Com sede estratégica no Brasil e hubs de distribuição na América do Norte, Europa e Ásia, a pjholz garante cobertura total de ponta a ponta. Através de nossos escritórios globais, coordenamos operações complexas alfandegárias e rastreamento local para simplificar a burocracia logística internacional.
      </p>
      
      <div class="location-details grid grid-2">
        <div class="location-hub">
          <i class="fa-solid fa-map-pin"></i>
          <div>
            <h4>Hub América do Sul</h4>
            <p>São Paulo, BR - Escritório Central & CD</p>
          </div>
        </div>
        <div class="location-hub">
          <i class="fa-solid fa-map-pin"></i>
          <div>
            <h4>Hub América do Norte</h4>
            <p>Miami, USA - Distribuição e Alfândega</p>
          </div>
        </div>
        <div class="location-hub">
          <i class="fa-solid fa-map-pin"></i>
          <div>
            <h4>Hub Europa</h4>
            <p>Rotterdam, NL - Logística Portuária</p>
          </div>
        </div>
        <div class="location-hub">
          <i class="fa-solid fa-map-pin"></i>
          <div>
            <h4>Hub Ásia</h4>
            <p>Singapore - Logística Multimodal</p>
          </div>
        </div>
      </div>

      <div class="location-cta">
        <a href="/contact" class="btn btn-primary">Fale Conosco</a>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section {
    position: relative;
    padding: 6rem 0;
    background-color: var(--color-secondary);
    overflow: hidden;
  }

  .map-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0.25;
    z-index: 0;
    transition: transform var(--transition-slow);
  }

  .location-section:hover .map-bg {
    transform: scale(1.03);
  }

  .map-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(6, 21, 28, 0.95) 40%, rgba(255, 90, 44, 0.15) 100%);
    z-index: 1;
  }

  .location-container {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 3rem;
  }

  /* Vertical text column styling */
  .vertical-title-col {
    display: flex;
    align-items: center;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    padding-right: 2rem;
  }

  .vertical-text {
    writing-mode: vertical-rl;
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.15);
    transform: rotate(180deg);
    white-space: nowrap;
  }

  /* Right content styling */
  .location-content {
    flex: 1;
  }

  .text-light {
    color: var(--color-text-light) !important;
  }

  .text-muted-light {
    color: rgba(248, 250, 252, 0.75) !important;
    margin-bottom: 2.5rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .location-details {
    gap: 2rem !important;
    margin-bottom: 3rem;
  }

  .location-hub {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .location-hub i {
    color: var(--color-accent);
    font-size: 1.5rem;
    margin-top: 0.25rem;
    animation: pulsePin 2s infinite;
  }

  .location-hub h4 {
    color: var(--color-text-light);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .location-hub p {
    color: rgba(248, 250, 252, 0.6);
    font-size: 0.9rem;
  }

  .location-cta {
    display: flex;
  }

  @keyframes pulsePin {
    0% {
      transform: scale(1);
      text-shadow: 0 0 0 rgba(255, 90, 44, 0.7);
    }
    70% {
      transform: scale(1.1);
      text-shadow: 0 0 10px rgba(255, 90, 44, 0.4);
    }
    100% {
      transform: scale(1);
      text-shadow: 0 0 0 rgba(255, 90, 44, 0);
    }
  }

  @media (max-width: 768px) {
    .location-container {
      flex-direction: column;
      gap: 1.5rem;
    }

    .vertical-title-col {
      display: none; /* Hide vertical text on mobile */
    }

    .location-details {
      grid-template-columns: 1fr;
    }
  }
</style>
