---
// Testimonials.astro
const reviews = [
  {
    name: "Juliana Mendes",
    role: "Diretora de Supply Chain na AutoParts S/A",
    avatar: "/images/ceo_avatar.png",
    text: "A pjholz transformou completamente nosso fluxo de importações. Os prazos são cumpridos com rigor britânico e o canal de suporte 24h deles é impecável."
  },
  {
    name: "Marcos Vinícius",
    role: "Diretor Comercial na MetalPrime S/A",
    avatar: "/images/ceo_avatar.png",
    text: "Tivemos uma operação de urgência aérea que outras transportadoras disseram ser impossível. A equipe da pjholz resolveu a alfândega e entregou em 36h."
  }
];
---

<section class="testimonials-section section-padding">
  <div class="container grid grid-2 align-items-center">
    <!-- Left Column: Branding Details & Avatars Group -->
    <div class="testimonials-info-side">
      <span class="badge-tag">Avaliações</span>
      <h2 class="section-title">O que Nossos Clientes Dizem</h2>
      <p class="section-desc">
        A melhor prova da qualidade do nosso serviço é a satisfação das empresas que atendemos diariamente. Ajudamos marcas líderes de mercado a reduzir custos de fretes e acelerar prazos logísticos.
      </p>

      <!-- Review Stars & Small Avatar Stack -->
      <div class="avatar-rating-group">
        <div class="avatar-stack">
          <img src="/images/ceo_avatar.png" alt="Client 1" class="stacked-avatar" />
          <img src="/images/ceo_avatar.png" alt="Client 2" class="stacked-avatar" />
          <img src="/images/ceo_avatar.png" alt="Client 3" class="stacked-avatar" />
        </div>
        <div class="rating-info">
          <div class="stars-gold">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>
          <span>Mais de <strong>2,500+</strong> Avaliações 5 Estrelas</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Cards Carousel/List -->
    <div class="testimonials-cards-side">
      {reviews.map((review) => (
        <div class="testimonial-card">
          <div class="quote-header flex-between">
            <i class="fa-solid fa-quote-left quote-icon"></i>
            <div class="stars-gold">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
          </div>
          <p class="testimonial-text">"{review.text}"</p>
          <div class="client-details">
            <img src={review.avatar} alt={review.name} class="client-avatar" />
            <div>
              <h4 class="client-name">{review.name}</h4>
              <span class="client-role">{review.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background-color: var(--color-bg-white);
  }

  .align-items-center {
    align-items: center;
  }

  /* Left column */
  .testimonials-info-side {
    padding-right: 2rem;
  }

  .avatar-rating-group {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .avatar-stack {
    display: flex;
  }

  .stacked-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-bg-white);
    margin-left: -15px;
    box-shadow: var(--shadow-md);
  }

  .stacked-avatar:first-child {
    margin-left: 0;
  }

  .rating-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stars-gold {
    color: #FFB800;
    font-size: 0.9rem;
  }

  .rating-info span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Right column */
  .testimonials-cards-side {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .testimonial-card {
    background-color: var(--color-bg-light);
    padding: 2.5rem;
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
  }

  .testimonial-card:hover {
    transform: translateX(8px);
    box-shadow: var(--shadow-md);
    background-color: var(--color-bg-white);
    border-left: 4px solid var(--color-accent);
  }

  .quote-icon {
    font-size: 2rem;
    color: var(--color-accent-soft);
  }

  .testimonial-text {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-dark);
  }

  .client-details {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .client-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: var(--shadow-sm);
  }

  .client-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .client-role {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 992px) {
    .testimonials-info-side {
      padding-right: 0;
      margin-bottom: 3rem;
    }
  }
</style>
