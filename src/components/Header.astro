---
// Header.astro
---

<header class="site-header">
  <!-- Top Bar -->
  <div class="top-bar">
    <div class="container flex-between">
      <div class="top-info">
        <span><i class="fa-solid fa-envelope"></i> contato@pjholz.com.br</span>
        <span><i class="fa-solid fa-phone"></i> +55 (11) 4002-8922</span>
      </div>
      <div class="top-right">
        <span><i class="fa-regular fa-clock"></i> Seg - Sex: 08:00 - 18:00</span>
        <div class="social-links">
          <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
          <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
          <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Navigation Bar -->
  <div class="main-nav-wrapper">
    <div class="container flex-between">
      <!-- Logo -->
      <a href="/" class="logo">
        <span class="logo-text">PJHOLZ</span>
      </a>

      <!-- Navigation Menu -->
      <nav class="nav-menu" id="navMenu">
        <ul>
          <li><a href="/" class="active">Home</a></li>
          <li><a href="/about">Sobre Nós</a></li>
          <li><a href="/services">Serviços</a></li>
          <li><a href="/contact">Contato</a></li>
        </ul>
      </nav>

      <!-- Right Header Actions -->
      <div class="header-actions">
        <button class="search-btn" aria-label="Search"><i class="fa-solid fa-magnifying-glass"></i></button>
        <a href="/contact#quote" class="btn btn-primary btn-quote">Solicitar Cotação</a>
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    width: 100%;
    position: relative;
    z-index: 100;
  }

  /* Top Bar Styles */
  .top-bar {
    background-color: var(--color-secondary);
    color: var(--color-text-light);
    font-size: 0.8rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border-dark);
  }

  .top-info {
    display: flex;
    gap: 1.5rem;
  }

  .top-info span, .top-right span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .top-info i, .top-right i {
    color: var(--color-accent);
  }

  .top-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    color: var(--color-text-muted);
    transition: var(--transition-fast);
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  /* Main Nav Styles */
  .main-nav-wrapper {
    background-color: var(--color-primary);
    padding: 1.25rem 0;
    box-shadow: var(--shadow-md);
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .logo-text:hover {
    color: var(--color-accent);
    transform: scale(1.03);
  }

  .nav-menu ul {
    display: flex;
    gap: 2rem;
  }

  .nav-menu a {
    font-family: var(--font-heading);
    color: var(--color-text-light);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0;
    position: relative;
  }

  .nav-menu a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: var(--transition-normal);
  }

  .nav-menu a:hover::after,
  .nav-menu a.active::after {
    width: 100%;
  }

  .nav-menu a:hover,
  .nav-menu a.active {
    color: var(--color-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .search-btn {
    color: var(--color-text-light);
    font-size: 1.2rem;
    transition: var(--transition-fast);
  }

  .search-btn:hover {
    color: var(--color-accent);
  }

  .btn-quote {
    padding: 0.65rem 1.5rem;
    font-size: 0.8rem;
  }

  .menu-toggle {
    display: none;
    color: var(--color-text-light);
    font-size: 1.5rem;
  }

  /* Responsive header */
  @media (max-width: 992px) {
    .top-bar {
      display: none; /* Hide top bar on mobile/tablet */
    }

    .menu-toggle {
      display: block;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: var(--color-primary-light);
      padding: 1.5rem;
      border-top: 1px solid var(--color-border-dark);
      display: none;
      box-shadow: var(--shadow-lg);
    }

    .nav-menu.active {
      display: block;
    }

    .nav-menu ul {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-menu a {
      display: block;
    }

    .btn-quote {
      display: none; /* Hide quote button on tablet/mobile header */
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('menuToggle');
  const navMenu = document.getElementById('navMenu');

  if (menuToggle && navMenu) {
    menuToggle.addEventListener('click', () => {
      navMenu.classList.toggle('active');
      const icon = menuToggle.querySelector('i');
      if (icon) {
        if (navMenu.classList.contains('active')) {
          icon.className = 'fa-solid fa-xmark';
        } else {
          icon.className = 'fa-solid fa-bars';
        }
      }
    });
  }
</script>
